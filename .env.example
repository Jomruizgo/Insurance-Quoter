# Copia este archivo a .env y completa los valores con credenciales reales.
# .env está en .gitignore — nunca commitees credenciales reales.

# ── Backend quoter — plataforma-danos-back (:8080) ───────────────────
BACK_DB_HOST=db-back
BACK_DB_PORT=5432
BACK_DB_NAME=insurance_quoter_db
BACK_DB_USER=change_me
BACK_DB_PASSWORD=change_me

# ── Backend core — plataforma-core-ohs (:8081) ───────────────────────
CORE_DB_NAME=insurance_core_db
CORE_DB_USER=change_me
CORE_DB_PASSWORD=change_me
CORE_DB_URL=jdbc:postgresql://db-core:5432/insurance_core_db

# ── Comunicación entre servicios ─────────────────────────────────────
CORE_SERVICE_BASE_URL=http://core:8081

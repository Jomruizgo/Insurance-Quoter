# Copy this file to .env and adjust values if needed.
# These are Docker-network addresses — not secrets.

# plataforma-danos-back DB host inside Docker network
BACK_DB_HOST=db-back
BACK_DB_PORT=5432

# plataforma-core-ohs JDBC URL inside Docker network
CORE_DB_URL=jdbc:postgresql://db-core:5432/insurance_core_db

# URL that plataforma-danos-back uses to reach plataforma-core-ohs
CORE_SERVICE_BASE_URL=http://core:8081

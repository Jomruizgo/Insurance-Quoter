{
  "title": "Insurance Quoter — Observabilidad",
  "uid": "insurance-quoter",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["insurance-quoter"],
  "panels": [
    {
      "id": 1,
      "title": "Mapa de servicios",
      "type": "nodeGraph",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(traces_service_graph_request_total[1m])) by (client, server)",
          "legendFormat": "{{client}} → {{server}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tasa de peticiones HTTP (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (job, uri, method)",
          "legendFormat": "{{job}} {{method}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Latencia HTTP p99 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, job, uri))",
          "legendFormat": "{{job}} {{uri}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Errores HTTP (5xx req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])) by (job, uri)",
          "legendFormat": "{{job}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 5,
      "title": "JVM Heap usado (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{job}} heap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "mbytes" }
      }
    },
    {
      "id": 6,
      "title": "Threads JVM activos",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "GC pause time (s/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum[1m])) by (job, action)",
          "legendFormat": "{{job}} {{action}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}

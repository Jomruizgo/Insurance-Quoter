                <mxCell id="uc_general" value="&lt;b&gt;ManageGeneralInfoUseCase&lt;/b&gt;&lt;br&gt;implements ManageGeneralInfoInputPort&lt;br&gt;─────────────────────&lt;br&gt;- quoteRepo: QuoteRepositoryPort&lt;br&gt;─────────────────────&lt;br&gt;+ get(folio): QuoteGeneralInfo&lt;br&gt;+ update(folio, data, version): QuoteGeneralInfo&lt;br&gt;  1. quoteRepo.findByFolio → optimistic lock check&lt;br&gt;  2. quote.updateGeneralInfo(data)&lt;br&gt;  3. quoteRepo.update(quote)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=6;" parent="1" vertex="1">

# Stage 1: clone + build
FROM node:20-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
RUN git clone --depth 1 https://github.com/Jomruizgo/Insurance-Quoter-Front.git .
RUN npm ci
RUN npm run build -- --configuration=production

# Stage 2: runtime
FROM nginx:alpine AS runtime
COPY --from=builder /app/dist/cotizador-danos-web/browser /usr/share/nginx/html
COPY nginx.docker.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
